# Insights Chatbot - Environment Configuration
# Copy this file to .env.local and fill in your values

# ==================== Application Settings ====================
FASTAPI_ENV=development
DEBUG=true
FASTAPI_HOST=127.0.0.1
FASTAPI_PORT=8000

# ==================== Azure OpenAI Settings ====================
# Get your Azure OpenAI API key from the Azure portal
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://ai-agents-interns-resource.cognitiveservices.azure.com/
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_MODEL_NAME=gpt-4.1
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4.1-khushi

# ==================== LangSmith Tracing (AI Debugging & Monitoring) ====================
# LangSmith is a platform for debugging, monitoring, and improving LLM applications
# Visit https://smith.langchain.com/ to create an account and get your API key

# Enable/disable LangSmith tracing
LANGSMITH_TRACING=true

# Your LangSmith API key (get from https://smith.langchain.com/settings/keys)
LANGSMITH_API_KEY=your_langsmith_api_key_here

# LangSmith endpoint (usually defaults to https://api.smith.langchain.com)
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Project name for organizing traces in LangSmith
# Traces from this application will be grouped under this project name
LANGSMITH_PROJECT=Insights

# ==================== Frontend ====================
NEXT_PUBLIC_API_URL=http://localhost:8000

# ==================== Storage Settings ====================
# Directory for uploaded dataset files
UPLOAD_DIR=/tmp/uploads

# Maximum upload file size (in bytes, default: 10 MB)
MAX_UPLOAD_SIZE=10485760

# Sandbox code execution timeout (in seconds)
SANDBOX_TIMEOUT=20

# ==================== Redis (Optional, for caching) ====================
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0

# ==================== MongoDB (Optional, for persistence) ====================
MONGODB_ENABLED=false
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=insights_chatbot

# ==================== Session Configuration ====================
# Session timeout duration (in hours)
SESSION_TIMEOUT_HOURS=24

# Cleanup interval for expired sessions (in minutes)
CLEANUP_INTERVAL_MINUTES=30

# ==================== Logging ====================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: json or text
LOG_FORMAT=json

# ==================== CORS Settings ====================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
